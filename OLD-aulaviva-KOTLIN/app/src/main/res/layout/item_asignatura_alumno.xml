<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textNombreAsignatura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre de la Asignatura"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="#2C3E50"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDescripcionAsignatura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Descripción de la asignatura"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="#7F8C8D"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textCodigoAcceso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#E8F5E9"
            android:padding="6dp"
            android:text="Código: ABC123"
            android:textColor="#27AE60"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="👉 Toca para ver clases"
            android:textColor="#4F3BB8"
            android:textSize="12sp"
            android:textStyle="italic" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
