{
  "$schema": "https://railway.app/railway.schema.json",
  "$comment": "Root Directory debe estar configurado como '/' (raíz) en Railway Dashboard. gradlew está en la raíz, no en backend/",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "chmod +x gradlew && ./gradlew :backend:bootJar -x test --no-build-cache"
  },
  "deploy": {
    "startCommand": "cd backend && java -jar build/libs/backend-1.0.0.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

