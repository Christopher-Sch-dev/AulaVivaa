<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permisos necesarios para la app -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Permiso para notificaciones en Android 13+ (Recurso Nativo) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Permisos para caché de PDFs (Android < 13) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Intent queries para buscar visores PDF (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/pdf" />
        </intent>
    </queries>

    <application
        android:name=".AulaVivaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AulaViva">
        <activity
            android:name=".presentation.ui.clases.ListaClasesActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.clases.DetalleClaseActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.main.PanelPrincipalActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.main.PanelAlumnoActivity"
            android:exported="false" />

        <!-- Pantalla de bienvenida Compose - Punto de entrada de la app -->
        <activity
            android:name=".presentation.ui.auth.compose.WelcomeActivityCompose"
            android:exported="true"
            android:theme="@style/Theme.AulaViva">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LoginActivity Compose -->
        <activity
            android:name=".presentation.ui.auth.compose.LoginActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- RegisterActivity Compose -->
        <activity
            android:name=".presentation.ui.auth.compose.RegisterActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- PanelPrincipalActivity Compose -->
        <activity
            android:name=".presentation.ui.main.compose.PanelPrincipalActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- PanelAlumnoActivity Compose -->
        <activity
            android:name=".presentation.ui.main.compose.PanelAlumnoActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- DocenteAsignaturasActivity Compose -->
        <activity
            android:name=".presentation.activity.compose.DocenteAsignaturasActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- AlumnoAsignaturasActivity Compose -->
        <activity
            android:name=".presentation.activity.compose.AlumnoAsignaturasActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- DocenteClasesActivity Compose -->
        <activity
            android:name=".presentation.activity.compose.DocenteClasesActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- AlumnoClasesActivity Compose -->
        <activity
            android:name=".presentation.activity.compose.AlumnoClasesActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- InscritosActivity Compose -->
        <activity
            android:name=".presentation.activity.compose.InscritosActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- DetalleClaseActivity Compose -->
        <activity
            android:name=".presentation.ui.clases.compose.DetalleClaseActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />

        <!-- CrearEditarClaseActivity Compose -->
        <activity
            android:name=".presentation.ui.clases.compose.CrearEditarClaseActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />
        
        <!-- ResultadoIAActivity Compose -->
        <activity
            android:name=".presentation.ui.ia.compose.ResultadoIAActivityCompose"
            android:exported="false"
            android:theme="@style/Theme.AulaViva" />
        <activity
            android:name=".presentation.activity.DocenteAsignaturasActivity"
            android:exported="false"
            android:label="Mis Asignaturas"
            android:parentActivityName=".presentation.ui.main.PanelPrincipalActivity" />
        <activity
            android:name=".presentation.activity.DocenteClasesActivity"
            android:exported="false"
            android:parentActivityName=".presentation.activity.DocenteAsignaturasActivity" />
        <activity
            android:name=".presentation.activity.InscritosActivity"
            android:exported="false"
            android:label="Alumnos Inscritos"
            android:parentActivityName=".presentation.activity.DocenteAsignaturasActivity" />
        <activity
            android:name=".presentation.ui.clases.CrearEditarClaseActivity"
            android:exported="false"
            android:parentActivityName=".presentation.activity.DocenteClasesActivity" />
        <activity
            android:name=".presentation.activity.AlumnoAsignaturasActivity"
            android:exported="false"
            android:label="Mis Asignaturas"
            android:parentActivityName=".presentation.ui.main.PanelPrincipalActivity" />
        <activity
            android:name=".presentation.activity.AlumnoClasesActivity"
            android:exported="false"
            android:parentActivityName=".presentation.activity.AlumnoAsignaturasActivity" />
    </application>

</manifest>
