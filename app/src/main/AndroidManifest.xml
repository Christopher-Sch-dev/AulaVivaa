<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permisos necesarios para la app -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Permiso para notificaciones en Android 13+ (Recurso Nativo) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Permisos para caché de PDFs (Android < 13) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Intent queries para buscar visores PDF (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/pdf" />
        </intent>
    </queries>

    <application
        android:name=".AulaVivaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AulaViva">
        <activity
            android:name=".presentation.ui.clases.ListaClasesActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.clases.DetalleClaseActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.main.PanelPrincipalActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.main.PanelAlumnoActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.LoginActivity"
            android:exported="false" />
        <!-- Pantalla de bienvenida - Punto de entrada de la app -->
        <activity
            android:name=".presentation.ui.auth.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".presentation.ui.ia.ResultadoIAActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.activity.DocenteAsignaturasActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.activity.AlumnoAsignaturasActivity"
            android:exported="false"
            android:label="Mis Asignaturas"
            android:parentActivityName=".presentation.ui.main.PanelPrincipalActivity" />
        <activity
            android:name=".presentation.activity.AlumnoClasesActivity"
            android:exported="false"
            android:parentActivityName=".presentation.activity.AlumnoAsignaturasActivity" />
    </application>

</manifest>
