<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@android:color/white">

    <!-- Espaciador superior -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Logo Grande -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚"
        android:textSize="80sp"
        android:layout_marginBottom="24dp"/>

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aula Viva"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:letterSpacing="0.02"
        android:layout_marginBottom="8dp"/>

    <!-- Subtítulo -->

    <!-- Botón SIGN IN (Iniciar Sesión) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="64dp"
        android:gravity="center"
        android:text="Da vida a las clases presenciales"
        android:textColor="#757575"
        android:textSize="15sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignIn"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Iniciar Sesión"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#1A237E"
        android:textColor="@android:color/white"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_lock_idle_lock"
        app:iconTint="@android:color/white"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:elevation="6dp"
        android:layout_marginBottom="16dp"/>

    <!-- Botón SIGN UP (Crear Cuenta) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignUp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Crear Cuenta Nueva"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:strokeColor="#1A237E"
        app:strokeWidth="2dp"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="#1A237E"
        app:iconGravity="textStart"
        app:iconPadding="12dp"/>

    <!-- Espaciador inferior -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"/>

    <!-- Footer con branding -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desarrollado para "
            android:textSize="12sp"
            android:textColor="#9E9E9E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XXXXX"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1A237E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 🎓"
            android:textSize="12sp"/>
    </LinearLayout>

</LinearLayout>
