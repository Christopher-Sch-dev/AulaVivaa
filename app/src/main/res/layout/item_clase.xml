<!-- Item de clase mejorado con descripción y badge de PDF -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardClase"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header con nombre y badge PDF -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textNombreClase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Nombre de la clase"
                android:textColor="#2C2C2C"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Badge PDF -->
            <TextView
                android:id="@+id/badgePdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:text="📄 PDF"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Descripción -->
        <TextView
            android:id="@+id/textDescripcionClase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Descripción de la clase"
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Fecha -->
        <TextView
            android:id="@+id/textFechaClase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="6dp"
            android:drawableTint="#999999"
            android:text="Fecha"
            android:textColor="#999999"
            android:textSize="13sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#EEEEEE" />

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <!-- Botón Editar -->
            <Button
                android:id="@+id/btnEditarClase"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="✏️ Editar"
                android:textAllCaps="false"
                android:textColor="#FF9800"
                android:textSize="12sp" />

            <!-- Botón Eliminar -->
            <Button
                android:id="@+id/btnEliminarClase"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="🗑️"
                android:textAllCaps="false"
                android:textColor="#F44336"
                android:textSize="16sp" />

            <!-- Botón ver detalles -->
            <Button
                android:id="@+id/btnVerDetalles"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Ver detalles"
                android:textAllCaps="false"
                android:textColor="#4F3BB8"
                android:textSize="13sp" />

            <!-- Botón compartir -->
            <Button
                android:id="@+id/btnCompartirClase"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📤"
                android:textAllCaps="false"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                app:strokeColor="#4CAF50" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
