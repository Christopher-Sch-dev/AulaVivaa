<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F8FCFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Campo nombre -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNombre"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Nombre de la asignatura"
            app:boxBackgroundColor="@android:color/white"
            app:boxStrokeColor="#4F3BB8"
            app:startIconDrawable="@android:drawable/ic_menu_edit"
            app:startIconTint="#4F3BB8">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:textColor="#2C2C2C"
                android:textColorHint="#757575"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDescripcion"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción (opcional)"
            app:boxBackgroundColor="@android:color/white"
            app:boxStrokeColor="#4F3BB8"
            app:startIconDrawable="@android:drawable/ic_menu_info_details"
            app:startIconTint="#4F3BB8">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:lines="3"
                android:maxLines="5"
                android:textColor="#2C2C2C"
                android:textColorHint="#757575"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nota informativa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="💡 Se generará un código único automáticamente para que los alumnos puedan inscribirse."
            android:textColor="#666666"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
