<!-- Pantalla de detalle de clase con funciones IA para docente -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FCFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header con botón volver -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnVolver"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Volver"
                android:textAllCaps="false"
                android:textColor="#4F3BB8" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="32sp" />
        </LinearLayout>

        <!-- Título de la clase -->
        <TextView
            android:id="@+id/textTituloClase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Título de la clase"
            android:textColor="#4F3BB8"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Fecha -->
        <TextView
            android:id="@+id/textFechaDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:drawablePadding="6dp"
            android:text="@string/lbl_fecha"
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Card descripción -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="📝 Descripción"
                    android:textColor="#2C2C2C"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textDescripcionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="Descripción completa de las actividades de la clase"
                    android:textColor="#666666"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card PDF (si existe) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="📄 Material de estudio"
                    android:textColor="#2C2C2C"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textNombrePdf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="documento.pdf"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnVerPdf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#039BE5"
                    android:text="@string/ver_pdf"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sección de IA para docente -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="@string/ia_herramientas"
            android:textColor="#4F3BB8"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Botón: Generar ideas para la clase -->
        <Button
            android:id="@+id/btnGenerarIdeas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#FF6F00"
            android:text="@string/ia_generar_ideas"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <!-- Botón: Sugerir actividades -->
        <Button
            android:id="@+id/btnSugerirActividades"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#8E24AA"
            android:text="@string/ia_sugerir_act_btn"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <!-- Botón: Estructurar clase por tiempo -->
        <Button
            android:id="@+id/btnEstructurarClase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#00897B"
            android:text="@string/ia_estructurar"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <!-- Botón: Analizar PDF con IA (solo si hay PDF) -->
        <Button
            android:id="@+id/btnAnalizarPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#D32F2F"
            android:text="@string/ia_analizar_pdf"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
